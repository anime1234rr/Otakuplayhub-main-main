{
  "extends": "astro/tsconfigs/base",
  "include": [
    ".astro/types.d.ts",
    "**/*"
  ],
  "exclude": [
    "dist"
  ],
  "compilerOptions": {
    "jsx": "react",  
    "strict": true,  
    "baseUrl": ".",  
    "paths": {
      "@components/*": ["src/components/*"], 
      "@layout/*": ["src/layout/*"]  
    }
  }
}
